###################### Functions ##########################

update_dotfiles() {
    chmod +x ~/.dotfiles/bootstrap.sh
    . ~/.dotfiles/bootstrap.sh
}

# Auto-ls for direcotry change
cd() { builtin cd "$@" && ls; }


# Count number of files in current directory
numfiles() { 
    N="$(ls $1 | wc -l)"; 
    echo "$N files in $1";
}

# Better man pages
man() {
   env \
    LESS_TERMCAP_mb=$(printf "\e[1;31m") \
    LESS_TERMCAP_md=$(printf "\e[1;31m") \
    LESS_TERMCAP_me=$(printf "\e[0m") \
    LESS_TERMCAP_se=$(printf "\e[0m") \
    LESS_TERMCAP_so=$(printf "\e[1;44;33m") \
    LESS_TERMCAP_ue=$(printf "\e[0m") \
    LESS_TERMCAP_us=$(printf "\e[1;32m") \
   man "$@"
}

# List IPs for running Docker Containers
function docker-ips() {
    docker ps | while read line; do
       if `echo $line | grep -q 'CONTAINER ID'`; then
          echo -e "IP ADDRESS\t$line"
       else
          CID=$(echo $line | awk '{print $1}');
          IP=$(docker inspect -f "{{ .NetworkSettings.IPAddress }}" $CID);
          printf "${IP}\t${line}\n"
       fi
    done;
}


# Determine size of a file or total size of a directory
function fs() {
	if du -b /dev/null > /dev/null 2>&1; then
		local arg=-sbh;
	else
		local arg=-sh;
	fi
	if [[ -n "$@" ]]; then
		du $arg -- "$@";
	else
		du $arg .[^.]* ./*;
	fi;
}

# Yes
function digga() {
	dig +nocmd "$1" any +multiline +noall +answer;
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring
# the `.git` directory, listing directories first. The output gets piped into
# `less` with options to preserve color and line numbers, unless the output is
# small enough for one screen.
function tre() {
	tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX;
}

function update_tmux_plugins() {
    printf "Install TPM plugins\n"
    tmux new -d -s __noop >/dev/null 2>&1 || true 
    tmux set-environment -g TMUX_PLUGIN_MANAGER_PATH "~/.config/tmux/plugins"
    "$HOME"/.config/tmux/plugins/tpm/bin/install_plugins || true
    tmux kill-session -t __noop >/dev/null 2>&1 || true
    printf "OK: Completed\n"
}

function utils_generate_options {
    echo "$@"
    ARR=($@)
    declare -A options
    for i in "${ARR[@]}"
    do
        options+=("$i")
        options+=("$i")
    done
    echo "${options[@]}"
    unset $ARR
}

function dcompose_update() {
    SERVICES=($(docker-compose ps --services))
    OPTIONS=($(utils_generate_options ${SERVICES[@]}))

    echo "${OPTIONS[@]}"

    if [ $? -eq 0]; then
        SELECTED=$(dialog --menu "In welchem Container soll 'composer update' ausgeführt werden?" 20 40 15 "${OPTIONS[@]}" 3>&1 1>&2 2>&3)
    fi

    if [ $? -eq 0 ] && [ -v $SELECTED]; then
        docker-compose exec -u propeller $SELECTED composer update 
    fi
    unset SELECTED
    unset OPTIONS
}















